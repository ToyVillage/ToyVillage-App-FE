{
  "name": "toyvillage-app-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "yarn lint && yarn typecheck && yarn build",
    "verify:e2e": "node scripts/run-scenarios.mjs",
    "harness:map-tokens": "node scripts/map-tokens.mjs",
    "harness:verify": "node scripts/verify.mjs",
    "harness:gate": "node scripts/gate-check.mjs",
    "harness:loop": "node scripts/loop-guard.mjs",
    "harness:approve": "node scripts/approve.mjs",
    "harness:visual": "node scripts/visual-check.mjs",
    "ok": "node scripts/visual-check.mjs --pass",
    "hooks:install": "node scripts/install-hooks.mjs",
    "e2e:setup": "yarn playwright install chromium",
    "postinstall": "node scripts/install-hooks.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.3"
  },
  "packageManager": "yarn@4.17.0"
}
